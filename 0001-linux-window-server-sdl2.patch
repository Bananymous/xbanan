+	shmdetacher.disable();
+	shmdeleter.disable();
 
 	if (m_fb_addr)
-		munmap(m_fb_addr, client_width() * client_height() * 4);
-	if (m_smo_key)
-		smo_delete(m_smo_key);
+		shmdt(m_fb_addr);
 
 	m_fb_addr = fb_addr;
-	m_smo_key = smo_key;
+	m_smo_key = shmid;
 
 	m_client_area.max_x = m_client_area.min_x + width;
 	m_client_area.max_y = m_client_area.min_y + height;
